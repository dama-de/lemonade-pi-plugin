  "description": "Pi.dev extension for Lemonade local LLM server. Adds Lemonade as a provider with built-in /login, UDP beacon discovery, and model administration.",
  "type": "module",
  "keywords": [
    "pi-package",
    "pi-extension",
    "lemonade",
    "llm",
    "local-ai",
    "local-llm"
  ],
  "license": "MIT",
  "author": "Lemonade SDK",
  "homepage": "https://github.com/lemonade-sdk/lemonade-pi-plugin",
  "repository": {
    "type": "git",
    "url": "https://github.com/lemonade-sdk/lemonade-pi-plugin.git"
  },
  "bugs": {
    "url": "https://github.com/lemonade-sdk/lemonade-pi-plugin/issues"
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "peerDependencies": {
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*"
  },
  "pi": {
    "extensions": [
      "extensions/index.ts"
    ]
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "@vitest/coverage-v8": "^4.1.7",
    "nock": "^14.0.15",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7",
    "vitest-mock-extended": "^4.0.0"
  }
}
