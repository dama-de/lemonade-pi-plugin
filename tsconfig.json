{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "./dist",
    "rootDir": "./extensions",
    "lib": ["ES2022", "DOM"],
    "types": [
      "node"
    ]
  },
  "include": ["extensions/**/*.ts"],
  "exclude": ["node_modules", "dist", "scripts"]
}
